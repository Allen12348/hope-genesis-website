# =============================================================================
# Production environment (Railway, VPS, Docker)
# Copy to `.env.production` when running Postgres commands from your laptop:
#   copy .env.production.example .env.production
# Do NOT commit `.env.production` (gitignored). Local dev uses `.env` + SQLite.
# =============================================================================

# Public site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# PostgreSQL — REQUIRED for npm run db:migrate:deploy / db:seed:production from your laptop.
# Railway: open your Postgres service → Connect → copy DATABASE_URL (entire string).
# It must look like: postgresql://postgres:...@monorail.proxy.rlwy.net:12345/railway
# Leave this line empty until you paste the real value (npm run db:check:production will verify).
DATABASE_URL=

# NextAuth (required)
NEXTAUTH_SECRET=generate-a-long-random-secret
NEXTAUTH_URL=https://your-domain.com

# Optional: first admin created by baseline seed (run inside production shell)
# ADMIN_SEED_EMAIL=admin@yourcompany.com
# ADMIN_SEED_PASSWORD=change-me-immediately

# Optional
OPENAI_API_KEY=
PRISMA_LOG_QUERIES=false
