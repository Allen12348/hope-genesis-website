# =============================================================================
# Production environment (Railway, VPS, Docker) — copy to hosting provider secrets
# Do NOT use for local `npm run dev` (use `.env` with SQLite instead).
# =============================================================================

# Public site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# PostgreSQL — Railway provides this automatically as DATABASE_URL
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# NextAuth (required)
NEXTAUTH_SECRET=generate-a-long-random-secret
NEXTAUTH_URL=https://your-domain.com

# Optional: first admin created by baseline seed (run inside production shell)
# ADMIN_SEED_EMAIL=admin@yourcompany.com
# ADMIN_SEED_PASSWORD=change-me-immediately

# Optional
OPENAI_API_KEY=
PRISMA_LOG_QUERIES=false
