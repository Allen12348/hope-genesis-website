{
  "name": "hge-site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "analyze": "cross-env ANALYZE=true next build",
    "analyze:server": "cross-env BUNDLE_ANALYZE=server ANALYZE=true next build",
    "analyze:browser": "cross-env BUNDLE_ANALYZE=browser ANALYZE=true next build",
    "bench:k6": "k6 run benchmarks/k6/public-routes.js",
    "bench:k6:local": "cross-env BASE_URL=http://localhost:3000 k6 run benchmarks/k6/public-routes.js",
    "bench:artillery": "artillery run benchmarks/artillery/public-routes.yml",
    "preview": "opennextjs-cloudflare build && node scripts/copy-prisma-engines.mjs && wrangler dev",
    "preview:node": "next build && next start -p 3000",
    "deploy": "opennextjs-cloudflare build && node scripts/copy-prisma-engines.mjs && wrangler deploy",
    "build:node": "next build",
    "db:migrate:d1": "wrangler d1 migrations apply hope-genesis-website --local",
    "db:migrate:d1:remote": "wrangler d1 migrations apply hope-genesis-website --remote",
    "db:seed:d1:local": "wrangler d1 execute hope-genesis-website --local --file=./scripts/d1-seed-dev-users.sql",
    "db:seed:d1:remote": "wrangler d1 execute hope-genesis-website --remote --file=./scripts/d1-seed-dev-users.sql",
    "start": "next start -p 3000",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:setup": "prisma db push && prisma db seed",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:status": "prisma migrate status",
    "db:migrate:deploy": "prisma migrate deploy --config prisma.config.postgres.ts",
    "db:migrate:sync-postgres-schema": "node scripts/sync-postgres-prisma-schema.mjs",
    "db:seed": "prisma db seed",
    "db:seed:baseline": "cross-env SEED_MODE=upsert prisma db seed",
    "db:seed:production": "cross-env SEED_MODE=upsert prisma db seed --config prisma.config.postgres.ts",
    "db:seed:production:reset": "prisma db seed --config prisma.config.postgres.ts",
    "db:deploy:production": "npm run db:migrate:sync-postgres-schema && npm run db:migrate:deploy && npm run db:seed:production",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@opennextjs/cloudflare": "1.15.0",
    "@prisma/adapter-d1": "^6.19.0",
    "@prisma/client": "^6.19.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.14.0",
    "next": "14.2.35",
    "next-auth": "^4.24.13",
    "next-themes": "^0.4.6",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.25.76"
  },
  "overrides": {
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250525.0",
    "@next/bundle-analyzer": "^14.2.35",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "artillery": "^2.0.31",
    "autoprefixer": "^10.5.0",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "prisma": "^6.19.0",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.20.6",
    "typescript": "^5",
    "wrangler": "^4.59.2"
  }
}
