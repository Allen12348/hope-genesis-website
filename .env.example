# =============================================================================
# Hope Genesis — environment template (local / testing)
# Copy to `.env` and adjust:  copy .env.example .env
# Never commit `.env` (real secrets). This file is safe to commit.
# =============================================================================

# -----------------------------------------------------------------------------
# Site (SEO, sitemap, canonical URLs)
# -----------------------------------------------------------------------------
# For local testing use http://localhost:3000 (must match how you open the app).
# Production example (must match your public hostname, no trailing slash):
#   NEXT_PUBLIC_SITE_URL=https://hopegenesisenterprises.dpdns.org
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Database — Node only (`next dev`, `npm run db:*`, Prisma Studio)
# -----------------------------------------------------------------------------
# SQLite `file:` paths are resolved relative to the Prisma schema folder (`prisma/`),
# not the repo root. Use `./dev.db` so the database file is `prisma/dev.db`.
DATABASE_URL=file:./dev.db

# -----------------------------------------------------------------------------
# Prisma — optional verbose SQL logging (Node / `next start` / `next dev`)
# -----------------------------------------------------------------------------
# Set to `true` to log every query, duration, and params to stdout.
PRISMA_LOG_QUERIES=false

# -----------------------------------------------------------------------------
# NextAuth (required for `/admin` login)
# -----------------------------------------------------------------------------
# Generate a real secret (PowerShell-friendly — no openssl required):
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#
# For quick local/testing only you can use a long random string; use a
# generated value above for anything shared or production-like.
NEXTAUTH_SECRET=HbfrlbHncYIMzAvs5EBUrRrv4eX2LlTE1NewPhvWPwU=
# Must match the URL users open in the browser (no trailing slash).
# Production: NEXTAUTH_URL=https://hopegenesisenterprises.dpdns.org
NEXTAUTH_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# HGE Assistant chat (`/api/chat/squirly`)
# -----------------------------------------------------------------------------
# Optional. When unset, the assistant uses deterministic HVAC heuristics only.
OPENAI_API_KEY=
# Optional override (default: gpt-4o-mini)
OPENAI_CHAT_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# Media library (admin uploads — local dev)
# -----------------------------------------------------------------------------
# Uploaded files are stored under public/uploads/media/ when using `npm run dev`.
# For Cloudflare production, configure an R2 bucket and public URL (coming soon).

# -----------------------------------------------------------------------------
# Admin — Visual page builder (optional debugging)
# -----------------------------------------------------------------------------
# Browser console: save/publish payload + builder state logs (client-side).
NEXT_PUBLIC_DEBUG_PAGE_BUILDER=false
# Server stdout: incoming save summaries when NODE_ENV=development, OR force with:
CMS_DEBUG_BUILDER_SAVE=false

# -----------------------------------------------------------------------------
# Notes
# -----------------------------------------------------------------------------
# - Next.js and Prisma only read `.env` / `.env.local` — NOT this file. Copy this
#   file to `.env` once; errors about DATABASE_URL or missing tables come from
#   `.env` + your actual `prisma/dev.db`, not from `.env.example`.
# - `npm run preview` (Wrangler) uses `.dev.vars` — see `.dev.vars.example`.
# - Local SQLite (Node / `next dev`):
#     npm run db:migrate:dev     # preferred — updates prisma/migrations + dev.db
#     npm run db:seed:baseline   # safe seed (keeps data)
#     npm run db:seed            # dev only — wipes tables then reseeds
#   Do NOT run `npx prisma migrate deploy` locally (use db:migrate:dev instead).
# - Railway / Postgres production: see `.env.production.example` and docs/DATABASE.md
#     npm run db:migrate:deploy  # runs against DATABASE_URL in production env only
# - Cloudflare D1: `npm run db:migrate:d1:remote` (repo-root `migrations/*.sql`, not prisma/migrations)
# - Stop `next dev` / `next start` before `npx prisma generate` on Windows (avoids EPERM
#   locking `query_engine-windows.dll.node`).
# - Required: DATABASE_URL (Node only), NEXTAUTH_SECRET, NEXTAUTH_URL
