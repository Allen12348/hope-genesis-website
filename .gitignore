# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/.open-next/
.wrangler/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env
.env*.local
.env.production
.dev.vars
/dev.db

# vercel
.vercel

# typescript
*.tsbuildinfo

# Postgres Prisma client (generated by npm run db:generate:postgres)
/generated/prisma-postgres
next-env.d.ts

# Prisma (custom output; contains machine-specific paths — regenerated via postinstall)
/prisma/generated

# Uploaded media (library files — keep folder structure)
/public/uploads/media/**
!/public/uploads/media/.gitkeep
